# ==============================================================================
# SRE Incident Triage Agent - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================================

# --- Anthropic / Claude ---
# Required. Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Optional. Default: claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# --- Slack ---
# Required for real Slack notifications.
# Create a webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=your-slack-webhook-url-here
SLACK_CHANNEL=#sre-incidents

# --- SendGrid Email ---
# Required for real email notifications.
# Get your API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# Sender email - must be a verified sender in SendGrid
SENDGRID_FROM_EMAIL=sre-agent@yourdomain.com
SENDGRID_FROM_NAME=SRE Triage Agent

# --- Database ---
# Default uses SQLite (no config needed for Docker Compose).
# Override for PostgreSQL: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/sre_agent.db

# --- Langfuse Observability ---
# These defaults work with the Docker Compose Langfuse stack.
# Change only if you're using Langfuse Cloud or a custom deployment.
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local

# Langfuse internal auth (used by the Langfuse container itself)
LANGFUSE_NEXTAUTH_SECRET=changeme-secret-at-least-32-chars!!
LANGFUSE_SALT=changeme-salt-at-least-32-chars!!!!!

# --- Application ---
# Set to true for verbose logging and SQL query echo
DEBUG=false

# CORS origins allowed (comma-separated if multiple)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
