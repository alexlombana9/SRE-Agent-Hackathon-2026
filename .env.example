# =============================================================================
# SRE Incident Intake & Triage Agent — Environment Variables
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
# =============================================================================

# --- LLM Provider ------------------------------------------------------------
# You only need ONE provider. OpenRouter recommended (one key, many models).

LLM_PROVIDER=openrouter               # Options: openrouter | anthropic | openai | google

# OpenRouter (recommended)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# Anthropic (direct)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GOOGLE_API_KEY=your-key-here
# GOOGLE_MODEL=gemini-2.0-flash

# LLM settings
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# --- Backend ------------------------------------------------------------------
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info                 # debug | info | warning | error

# --- Frontend -----------------------------------------------------------------
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000     # Backend URL visible to the browser

# --- Database -----------------------------------------------------------------
DATABASE_URL=sqlite:///./data/incidents.db

# --- Ticketing (mocked by default) -------------------------------------------
TICKET_SYSTEM=mock                     # mock | jira | linear
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your-token
# JIRA_PROJECT_KEY=SRE

# --- Email (mocked by default) -----------------------------------------------
EMAIL_SYSTEM=mock                      # mock | smtp | sendgrid
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password

# --- Chat Notifications (mocked by default) ----------------------------------
CHAT_SYSTEM=mock                       # mock | slack | discord
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# --- Observability (Langfuse) ------------------------------------------------
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=http://langfuse:3000     # Internal Docker URL

# --- E-Commerce Codebase -----------------------------------------------------
ECOMMERCE_REPO=https://github.com/reactioncommerce/reaction
ECOMMERCE_LOCAL_PATH=/app/ecommerce-repo
