# ==============================================================================
# Trusty SRE AI Agent Platform - Environment Variables
# ==============================================================================
#
# This file documents ALL environment variables used by the project.
#
# Frontend variables (VITE_*) go in .env.local — see .env.local.example
# Backend variables go in the Convex Dashboard → Settings → Environment Variables
#
# ==============================================================================

# --- Convex Environment Variables ---
# Set these in the Convex Dashboard (https://dashboard.convex.dev)
# under Settings → Environment Variables for your deployment.

# --- Anthropic / Claude ---
# Required. Powers all AI agents.
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Optional. Default: claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# --- Linear (Ticketing) ---
# Required. Ticketer Agent creates issues here.
# Get your API key at https://linear.app/settings/api
LINEAR_API_KEY=lin_api_your-key-here
LINEAR_TEAM_ID=your-linear-team-id

# --- Slack ---
# Required. Notifier Agent sends incident alerts.
# Create a webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_INCIDENTS_CHANNEL=#sre-incidents
SLACK_CRITICAL_CHANNEL=#sre-critical

# --- Discord ---
# Required. Notifier Agent sends incident alerts.
# Create a webhook in Discord server settings.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# --- Resend (Email) ---
# Required. Notifier Agent sends email to teams and reporters.
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=sre-agent@yourdomain.com

# --- Twilio (SMS — Critical incidents only) ---
# Optional. Only triggered for Critical severity incidents.
# Get credentials at https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_ONCALL_NUMBER=+1987654321

# --- Langfuse (Observability) ---
# Required. Tracks LLM traces, token usage, latency, cost.
# https://cloud.langfuse.com or self-hosted
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_SECRET_KEY=sk-lf-your-key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Vercel Sandbox (Autonomous Debugging) ---
# Required for Debugger Agent. Provides isolated code execution.
# https://vercel.com/docs/vercel-sandbox/sdk-reference
VERCEL_TOKEN=your-vercel-token
