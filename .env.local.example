# Convex — run `npx convex dev` to get this after deploying
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk — from https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Clerk JWT template for Convex — set in Clerk dashboard → JWT Templates → Convex
# Then set CLERK_FRONTEND_API_URL in your Convex dashboard environment variables
# CLERK_FRONTEND_API_URL=https://your-clerk-frontend-api.clerk.accounts.dev
